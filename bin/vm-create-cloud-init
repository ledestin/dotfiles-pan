#!/bin/bash

set -e

write_alpine_user_data() {
cat >user-data <<-EOF
#cloud-config
users:
  - name: alpine
    ssh_authorized_keys:
      - $PUB_KEY
EOF
}

write_generic_user_data() {
cat >user-data <<-EOF
#cloud-config
packages:
  - sudo
users:
  - name: ledestin
    ssh-authorized-keys:
      - $PUB_KEY
    sudo: ['ALL=(ALL) NOPASSWD:ALL']
    groups: sudo
    shell: $shell
runcmd:
  - echo "AllowUsers ledestin" >> /etc/ssh/sshd_config
  - restart ssh
EOF
}

instance_name="$1"
instance_dir="$HOME/images/$instance_name"
iso_image="$instance_dir/$instance_name-cidata.iso"

if [[ -z "$instance_name" ]]; then
  echo >&2 "Usage: $(basename "$0") <instance_name>"
  exit 1
fi

create_init_files() {
cat >meta-data <<-EOF
instance-id: id-$instance_name
local-hostname: $instance_name
EOF

  PUB_KEY=$(cat ~/.ssh/id_ed25519.pub)
  if is_alpine; then
    write_alpine_user_data
    return
  fi

  write_generic_user_data
}

create_iso() {
  genisoimage -output "$iso_image" \
    -volid cidata -joliet -rock user-data meta-data
}

is_alpine() {
  echo "$instance_name" | grep -qi alpine
}

tmp_dir=$(mktemp -d)
trap 'rm -r $tmp_dir' EXIT

mkdir -p "$instance_dir"

shell=/bin/bash
if is_alpine; then
  shell=/bin/sh
fi

cd "$tmp_dir"
create_init_files
create_iso

echo
echo "Created cloud init $iso_image"
